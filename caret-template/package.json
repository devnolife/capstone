    "lenis": "^1.3.25",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.496",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.496",
    "@remotion/tailwind-v4": "^4.0.496",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8.20.0",
