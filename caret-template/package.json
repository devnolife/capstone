{
  "name": "caret-nextjs-template",
  "version": "0.1.0",
  "private": true,
  "description": "Caret-style Next.js template: dark zinc design system, GSAP + Lenis motion layer, Remotion Player demos, and a matching dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
